{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "image": "latest" }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "ios": { "image": "latest" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6698851328"
      }
    }
  }
}
